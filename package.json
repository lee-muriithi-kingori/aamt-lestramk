  "license": "MIT",
  "homepage": "https://github.com/lee-muriithi-kingori/aamt-lestramk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lee-muriithi-kingori/aamt-lestramk.git"
  },
  "bugs": {
    "url": "https://github.com/lee-muriithi-kingori/aamt-lestramk/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
